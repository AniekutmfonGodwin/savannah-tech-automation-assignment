FROM python:3.12-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1

WORKDIR /workspace

COPY pyproject.toml README.md ./
COPY src ./src
COPY tests ./tests
COPY config ./config

RUN pip install --no-cache-dir -e .

CMD ["pytest", "--html=reports/report.html", "--self-contained-html", "--junitxml=reports/junit.xml", "-m", "not schemathesis"]
