# Example environment overrides.  Real secrets must NOT live in YAML profiles
# (config/environments/*.yaml) — those reference env var names only.  Copy
# this file to `.env` for local development and fill in any overrides you need.
#
# Resolution order (highest precedence last):
#   1. defaults in src/firefly_qa/env_loader.py
#   2. YAML profile selected by FIREFLY_ENV (default: local)
#   3. these FIREFLY_* environment variables
#   4. `pytest --env=<name>` CLI flag (selects profile)

# Which YAML profile to load.  See config/environments/*.yaml for options.
FIREFLY_ENV=local

# Base API location
FIREFLY_BASE_URL=http://localhost:8080
FIREFLY_API_BASE_PATH=/api/v1
FIREFLY_SPEC_PATH=/swagger/doc.json
FIREFLY_REQUEST_TIMEOUT_SECONDS=15

# Pre-populated tenant credentials.  In real environments these would come
# from Vault / GitHub Actions secrets / AWS Secrets Manager.
FIREFLY_TEST1_USERNAME=test1
FIREFLY_TEST1_PASSWORD=test123
FIREFLY_TEST2_USERNAME=test2
FIREFLY_TEST2_PASSWORD=test456

# Load testing knobs (consumed by tests/test_load.py)
FIREFLY_LOAD_RPM=1000
FIREFLY_LOAD_DURATION_SECONDS=60
